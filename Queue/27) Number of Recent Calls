class RecentCounter:
    def __init__(self):
        self.prev_calls = deque()

    def ping(self, t: int) -> int:
        self.prev_calls.append(t)

        while self.prev_calls[0] < t-3000:
            self.prev_calls.popleft()
        
        return len(self.prev_calls)



