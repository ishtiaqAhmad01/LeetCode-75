class Solution:
    def maxOperations(self, nums: List[int], k: int) -> int:
        key_val = {}
        count = 0

        for num in nums:
            if k-num in key_val and key_val[k-num] != 0:
                key_val[k-num]-=1
                count+=1
            else:
                if num in key_val:
                    key_val[num] += 1
                else:
                    key_val[num] = 1 
        
        return count
